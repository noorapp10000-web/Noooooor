<?xml version="1.0" encoding="utf-8"?>
<!--
    Square adaptive icon: the foreground fills the full 108dp layer
    (no safe-zone inset) so the logo appears square even when the launcher
    applies a squircle/circle mask — the logo fills the entire visible area.
    Background matches the cream logo background.
-->
<adaptive-icon xmlns:android="http://schemas.android.com/apk/res/android">
    <background android:drawable="@color/ic_launcher_background"/>
    <foreground android:drawable="@mipmap/ic_launcher_foreground"/>
</adaptive-icon>
