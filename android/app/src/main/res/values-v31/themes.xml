<?xml version="1.0" encoding="utf-8"?>
<!--
    Android 12+ (API 31+) — Mandatory system splash screen configuration.
    The OS shows this splash automatically BEFORE the Activity starts.

    Strategy to show the logo cleanly (no zoom, no cropping):
    - windowSplashScreenBackground        = cream (#F5E6CC) — matches app background
    - windowSplashScreenIconBackgroundColor = cream (same as above) — hides the circular border
    - windowSplashScreenAnimatedIcon      = @drawable/splash_logo — the Noor logo,
      fitted proportionally into the icon area (no cropping, no distortion)

    Result: Logo appears centered on a cream background with no visible circle.
-->
<resources>
    <style name="AppTheme.NoActionBarLaunch" parent="Theme.SplashScreen">
        <item name="android:windowSplashScreenBackground">@color/splash_background</item>
        <item name="android:windowSplashScreenAnimatedIcon">@drawable/splash_logo</item>
        <item name="android:windowSplashScreenIconBackgroundColor">@color/splash_background</item>
        <item name="postSplashScreenTheme">@style/AppTheme.NoActionBar</item>
        <item name="android:windowFullscreen">true</item>
    </style>
</resources>
