<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_bg"
    android:padding="12dp"
    android:gravity="center_horizontal">

    <!-- Date row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center">

        <TextView
            android:id="@+id/widget_hijri_date"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="1 Muharram 1446 AH"
            android:textColor="#C19A6B"
            android:textSize="9sp"
            android:gravity="center"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.05" />

        <TextView
            android:id="@+id/widget_gregorian_date"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Thursday, 15 May 2026"
            android:textColor="#99FFFFFF"
            android:textSize="8sp"
            android:gravity="center"
            android:fontFamily="sans-serif"
            android:layout_marginTop="1dp" />
    </LinearLayout>

    <!-- Thin gold divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#40C19A6B"
        android:layout_marginTop="7dp"
        android:layout_marginBottom="7dp" />

    <!-- "NEXT PRAYER" label -->
    <TextView
        android:id="@+id/widget_label"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="NEXT PRAYER"
        android:textColor="#66FFFFFF"
        android:textSize="7sp"
        android:gravity="center"
        android:letterSpacing="0.20"
        android:fontFamily="sans-serif" />

    <!-- Prayer name (English) -->
    <TextView
        android:id="@+id/widget_prayer_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Maghrib"
        android:textColor="#FFFFFF"
        android:textSize="20sp"
        android:gravity="center"
        android:fontFamily="sans-serif-medium"
        android:layout_marginTop="2dp" />

    <!-- Countdown container -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_marginTop="6dp">

        <!-- HH:MM:SS Chronometer -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center">
                <TextView
                    android:id="@+id/widget_hours"
                    android:layout_width="32dp"
                    android:layout_height="28dp"
                    android:background="@drawable/widget_digit_bg"
                    android:text="00"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:gravity="center"
                    android:fontFamily="sans-serif-medium" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="HR"
                    android:textColor="#55FFFFFF"
                    android:textSize="6sp"
                    android:gravity="center"
                    android:layout_marginTop="1dp"
                    android:fontFamily="sans-serif" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=":"
                android:textColor="#C19A6B"
                android:textSize="18sp"
                android:fontFamily="sans-serif-medium"
                android:paddingStart="3dp"
                android:paddingEnd="3dp"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center">
                <TextView
                    android:id="@+id/widget_minutes"
                    android:layout_width="32dp"
                    android:layout_height="28dp"
                    android:background="@drawable/widget_digit_bg"
                    android:text="00"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:gravity="center"
                    android:fontFamily="sans-serif-medium" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="MIN"
                    android:textColor="#55FFFFFF"
                    android:textSize="6sp"
                    android:gravity="center"
                    android:layout_marginTop="1dp"
                    android:fontFamily="sans-serif" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=":"
                android:textColor="#C19A6B"
                android:textSize="18sp"
                android:fontFamily="sans-serif-medium"
                android:paddingStart="3dp"
                android:paddingEnd="3dp"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center">
                <TextView
                    android:id="@+id/widget_seconds"
                    android:layout_width="32dp"
                    android:layout_height="28dp"
                    android:background="@drawable/widget_digit_bg"
                    android:text="00"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:gravity="center"
                    android:fontFamily="sans-serif-medium" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SEC"
                    android:textColor="#55FFFFFF"
                    android:textSize="6sp"
                    android:gravity="center"
                    android:layout_marginTop="1dp"
                    android:fontFamily="sans-serif" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- Prayer time -->
    <TextView
        android:id="@+id/widget_prayer_time"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="At 6:41 PM"
        android:textColor="#C19A6B"
        android:textSize="10sp"
        android:gravity="center"
        android:fontFamily="sans-serif"
        android:layout_marginTop="5dp" />

</LinearLayout>
